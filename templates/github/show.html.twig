{% extends 'base.html.twig' %}

{% block title %}{{ repo.name }}{% endblock %}

{% block body %}
<a href="{{ path('github_index') }}" class="btn btn-secondary btn-sm mb-3">&larr; Back to list</a>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h1 class="h4 mb-0">
            <a href="{{ repo.url }}" target="_blank" rel="noopener noreferrer">{{ repo.name }}</a>
        </h1>
        <span class="badge bg-warning text-dark fs-6">&#9733; {{ repo.starsCount|number_format }} stars</span>
    </div>
    <div class="card-body">
        <table class="table table-bordered mb-0">
            <tbody>
                <tr>
                    <th style="width:200px">GitHub ID</th>
                    <td>{{ repo.githubId }}</td>
                </tr>
                <tr>
                    <th>Repository URL</th>
                    <td><a href="{{ repo.url }}" target="_blank" rel="noopener noreferrer">{{ repo.url }}</a></td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ repo.description ?? '—' }}</td>
                </tr>
                <tr>
                    <th>Created</th>
                    <td>{{ repo.createdAt|date('Y-m-d') }}</td>
                </tr>
                <tr>
                    <th>Last Push</th>
                    <td>{{ repo.pushedAt|date('Y-m-d') }}</td>
                </tr>
                <tr>
                    <th>Stars</th>
                    <td>{{ repo.starsCount|number_format }}</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
