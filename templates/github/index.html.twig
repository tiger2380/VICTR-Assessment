{% extends 'base.html.twig' %}

{% block title %}Top Starred PHP Repositories{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Top Starred PHP Repositories</h1>
    <form method="post" action="{{ path('github_refresh') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('github_refresh') }}">
        <button type="submit" class="btn btn-primary">
            &#x21bb; Refresh from GitHub
        </button>
    </form>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger">{{ message }}</div>
{% endfor %}

{% if repos is empty %}
    <div class="alert alert-info">
        No repositories loaded yet. Click <strong>Refresh from GitHub</strong> to fetch data.
    </div>
{% else %}
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Repository</th>
                <th class="text-end">&#9733; Stars</th>
            </tr>
        </thead>
        <tbody>
            {% for repo in repos %}
            <tr style="cursor:pointer;" onclick="window.location='{{ path('github_show', {githubId: repo.githubId}) }}'">
                <td>{{ loop.index }}</td>
                <td>{{ repo.name }}</td>
                <td class="text-end">{{ repo.starsCount|number_format }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <p class="text-muted small">Click a row to view full details.</p>
{% endif %}
{% endblock %}
